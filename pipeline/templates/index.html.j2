<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Entheocast — Psychedelic Research Tracker</title>
  <meta name="description" content="Psychedelic clinical trials, regulatory updates, and research — aggregated weekly from PubMed, ClinicalTrials.gov, Semantic Scholar, and primary news sources. Open data, MIT licensed.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="style.css">
  <script defer src="molecules.js"></script>
  <style>
    .layout { display: grid; grid-template-columns: 1fr 240px; gap: 4rem; align-items: start; }
    @media (max-width: 768px) {
      .layout { grid-template-columns: 1fr; gap: 2rem; }
      .issue-date { font-size: 1.3rem; }
    }

    /* Issue hero */
    .issue-block { position: relative; margin-bottom: 2rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); overflow: hidden; }
    .ambient-num { position: absolute; top: -1.5rem; left: -0.75rem; font-family: 'Syne',sans-serif; font-weight: 800; font-size: 9rem; line-height: 1; color: var(--accent); opacity: 0.05; pointer-events: none; letter-spacing: -0.03em; user-select: none; }
    .issue-kicker { font-size: 0.68rem; font-weight: 600; letter-spacing: 0.16em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.4rem; position: relative; }
    .issue-date { font-family: 'Syne',sans-serif; font-weight: 700; font-size: 1.65rem; color: var(--text); line-height: 1.2; margin-bottom: 0.55rem; position: relative; }
    .issue-desc { font-size: 0.84rem; color: var(--dim); margin-bottom: 1rem; position: relative; }
    .issue-desc strong { color: var(--text); font-weight: 600; }
    .issue-cta { font-size: 0.78rem; font-weight: 600; letter-spacing: 0.04em; color: var(--accent); text-decoration: none; position: relative; }
    .issue-cta:hover { text-decoration: underline; }

    /* Spotlight */
    .spotlight { background: var(--surface); border: 1px solid var(--border); border-left: 3px solid var(--accent); border-radius: 5px; padding: 1.15rem 1.4rem; margin-bottom: 2rem; }
    .spotlight-flag { font-size: 0.63rem; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.4rem; }
    .spotlight h3 { font-family: 'Syne',sans-serif; font-size: 0.97rem; font-weight: 700; color: var(--text); line-height: 1.35; margin-bottom: 0.5rem; }
    .spotlight p { font-size: 0.81rem; color: var(--dim); line-height: 1.6; margin-bottom: 0.7rem; }
    .spotlight-date { font-size: 0.7rem; color: var(--muted); margin-bottom: 0.6rem; }
    .spotlight-link { font-size: 0.76rem; font-weight: 600; color: var(--accent); text-decoration: none; }
    .spotlight-link:hover { text-decoration: underline; }

    /* Entry cards */
    .entry-card { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: 1.2rem 1.4rem; margin-bottom: 0.75rem; transition: border-color 0.15s; }
    .entry-card:hover { border-color: var(--border-strong); }
    .entry-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.85rem; margin-bottom: 0.5rem; }
    .entry-badges { display: flex; gap: 0.4rem; flex-shrink: 0; flex-wrap: wrap; justify-content: flex-end; }
    .entry-h { font-size: 0.91rem; font-weight: 600; line-height: 1.45; color: var(--text); }
    .entry-h a { color: inherit; text-decoration: none; }
    .entry-h a:hover { color: var(--accent); }
    .entry-source { font-size: 0.7rem; color: var(--muted); margin-top: 0.2rem; }
    .entry-summary { margin-top: 0.85rem; padding-top: 0.85rem; border-top: 1px solid var(--border); font-size: 0.82rem; color: var(--dim); line-height: 1.65; }
    .entry-footer { margin-top: 0.9rem; display: flex; justify-content: flex-end; }
    .source-link { font-size: 0.73rem; font-weight: 600; color: var(--accent); text-decoration: none; }
    .source-link:hover { text-decoration: underline; }

    /* Simple entries (live feed) */
    .entry-simple { display: flex; align-items: flex-start; gap: 0.85rem; padding: 0.9rem 0; border-bottom: 1px solid var(--border); }
    .entry-simple:last-child { border-bottom: none; }
    .entry-simple-body { flex: 1; min-width: 0; }
    .entry-simple-title { font-size: 0.86rem; line-height: 1.48; margin-bottom: 0.18rem; }
    .entry-simple-title a { color: var(--text); text-decoration: none; }
    .entry-simple-title a:hover { color: var(--accent); }
    .entry-simple-meta { font-size: 0.7rem; color: var(--muted); }

    .muted-text { font-size: 0.8rem; color: var(--dim); line-height: 1.65; }
    .muted-text a { color: var(--accent); text-decoration: none; }
    .muted-text a:hover { text-decoration: underline; }
  </style>
</head>
<body>

<!-- Floating molecular ring structures
     mol-1,4: Indole (bicyclic core of DMT, psilocybin, LSD, serotonin — benzene fused to N-containing pyrrole)
     mol-2:   Naphthalene (two fused aromatic hexagons)
     mol-3:   Benzene (aromatic hexagonal ring with delocalized electrons, shown as dashed inner circle)
     mol-5:   Pyridine (6-membered ring with one nitrogen — present in many plant alkaloids) -->
<div class="page">
<header>
  <div class="header-inner">
    <a href="index.html" class="wordmark">ENTHEO<span class="dot">·</span>CAST</a>
    <nav>
      <a href="index.html" class="active">Home</a>
      <a href="trials.html">Trials</a>
      <a href="weekly/index.html">Weekly</a>
      <a href="podcast.html">Podcast</a>
      <a href="about.html">About</a>
      <a href="contact.html">Contact</a>
    </nav>
  </div>
</header>

<main class="main-wrap">
  <div class="layout">
    <div>

      <div class="issue-block">
        <div class="issue-kicker">Week {{ week_num }} · {{ month_year }}</div>
        <div class="issue-date">{{ month_year }}</div>
        <p class="issue-desc">A curated, open repository of psychedelic clinical trials, research, and regulatory updates. <strong id="stat-entries">{{ total }}</strong> entries — updated weekly.</p>
        <a href="weekly/{{ week_key }}.html" class="issue-cta">Read this week's full issue →</a>
      </div>

      {% if spotlight %}
      <div class="spotlight">
        <div class="spotlight-flag">{{ type_labels.get(spotlight.type, spotlight.type) }}{% if spotlight.compound and spotlight.compound != 'other' %} · {{ compound_labels.get(spotlight.compound, spotlight.compound) }}{% elif spotlight.institution %} · {{ spotlight.institution.split('/')[0].strip() }}{% endif %}</div>
        <h3>{{ spotlight.title }}</h3>
        {% set spotlight_blurb = spotlight | blurb %}
        {% if spotlight_blurb %}
        <p>{{ spotlight_blurb }}</p>
        {% endif %}
        {% if spotlight.date %}<div class="spotlight-date">{{ spotlight.date | fmt_date }}</div>{% endif %}
        <a href="{{ spotlight.url }}" target="_blank" rel="noopener" class="spotlight-link">Read on {{ spotlight.source }} →</a>
      </div>
      {% endif %}

      <div class="section-label">Featured This Week</div>

      {% for entry in featured %}
      <div class="entry-card">
        <div class="entry-top">
          <div>
            <div class="entry-h"><a href="{{ entry.url }}" target="_blank" rel="noopener">{{ entry.title }}</a></div>
            <div class="entry-source">{{ entry.source }}{% if entry.date %} · {{ entry.date | fmt_date }}{% endif %}</div>
          </div>
          <div class="entry-badges">
            <span class="chip {{ entry.compound or 'other' }}">{{ compound_labels.get(entry.compound, 'Other') }}</span>
            {% if entry.type in type_labels %}<span class="type-chip">{{ type_labels[entry.type] }}</span>{% endif %}
          </div>
        </div>
        {% set entry_blurb = entry | blurb %}
        {% if entry_blurb %}
        <div class="entry-summary">{{ entry_blurb }}</div>
        {% endif %}
        <div class="entry-footer"><a href="{{ entry.url }}" target="_blank" rel="noopener" class="source-link">Read on {{ entry.source }} →</a></div>
      </div>
      {% endfor %}

      <div class="section-label" style="margin-top:2rem">More from the Feed</div>
      <div id="entry-list">
        {% for entry in feed %}
        <div class="entry-simple">
          <div class="entry-simple-body">
            <div class="entry-simple-title"><a href="{{ entry.url }}" target="_blank" rel="noopener">{{ entry.title }}</a></div>
            <div class="entry-simple-meta">{{ type_labels.get(entry.type, entry.type or '') }}{% if entry.date %} · {{ entry.date | fmt_date }}{% endif %}{% if entry.institution %} · {{ entry.institution[:44] }}{% endif %}</div>
          </div>
          <span class="chip {{ entry.compound or 'other' }}">{{ compound_labels.get(entry.compound, 'Other') }}</span>
        </div>
        {% endfor %}
      </div>
      <p class="view-all"><a href="trials.html">View all entries →</a></p>

    </div>

    <aside>
      <div class="sidebar-block">
        <div class="sidebar-label">By Compound</div>
        <div id="compound-bars"><div style="font-size:0.78rem;color:var(--muted)">Loading...</div></div>
      </div>
      <div class="sidebar-block">
        <div class="sidebar-label">About</div>
        <p class="muted-text">Psychedelic clinical trials, regulatory updates, and research — aggregated weekly from PubMed, ClinicalTrials.gov, Semantic Scholar, and curated news sources. Open data, MIT licensed.</p>
        <p class="muted-text" style="margin-top:0.6rem"><a href="about.html">Methodology →</a>&emsp;<a href="data/entries.json">Raw JSON →</a></p>
      </div>
    </aside>
  </div>
</main>

<footer>
  <span>Entheocast · Open data · MIT</span>
  <span><a href="https://github.com/ianjamesburke/entheocast">GitHub</a> · Updated weekly</span>
</footer>
</div>

<script>
// The feed and entry count are rendered at build time. This only draws the compound
// bars, which need the full corpus rather than the ten entries already on the page.
const COMPOUND_LABELS = { psilocybin:"Psilocybin", mdma:"MDMA", ketamine:"Ketamine", lsd:"LSD", dmt:"DMT", ibogaine:"Ibogaine", ayahuasca:"Ayahuasca", mescaline:"Mescaline", other:"Other" };
const COMPOUND_ORDER = ["psilocybin","mdma","ketamine","lsd","dmt","ibogaine","ayahuasca","mescaline","other"];

fetch("data/entries.json").then(r=>r.json()).then(entries=>{
  const counts={};
  entries.forEach(e=>{ const c=e.compound||"other"; counts[c]=(counts[c]||0)+1; });
  const max=Math.max(...Object.values(counts));
  document.getElementById("compound-bars").innerHTML=COMPOUND_ORDER.filter(c=>counts[c]).map(c=>`<div class="cbar"><span class="cbar-name">${COMPOUND_LABELS[c]||c}</span><div class="cbar-track"><div class="cbar-fill" style="width:${Math.round(counts[c]/max*100)}%"></div></div><span class="cbar-count">${counts[c]}</span></div>`).join("");
}).catch(()=>{
  document.getElementById("compound-bars").innerHTML='<div style="font-size:0.78rem;color:var(--muted)">Open via HTTP server to load breakdown.</div>';
});
</script>
</body>
</html>
